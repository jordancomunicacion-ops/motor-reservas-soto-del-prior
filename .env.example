# Postgres
DB_NAME=reservas
DB_USER=reservas_user
DB_PASS=

# NextAuth (apps/web) — generate with: openssl rand -base64 32
AUTH_SECRET=

# Nest JWT (apps/motor-reservas) — generate with: openssl rand -base64 32
JWT_SECRET=

# Optional bootstrap admin for the very first login (until installer creates a real admin).
# Leave empty in production once you have at least one admin user in DB.
# Password must be at least 8 chars; both must be set together or the bootstrap path is disabled.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Prisma seed (apps/web): used only when running `npx prisma db seed`.
# Required to create the initial ADMIN user; password >= 8 chars.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin
